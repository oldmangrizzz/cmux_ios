app_identifier("com.cmuxterm.ios")

# App Store Connect API key configuration
# Set these as environment variables in GitHub Actions or your local shell:
#   APP_STORE_CONNECT_API_KEY_KEY_ID
#   APP_STORE_CONNECT_API_KEY_ISSUER_ID
#   APP_STORE_CONNECT_API_KEY_KEY_CONTENT
#
# To create an API key:
# 1. Go to App Store Connect > Users and Access > Keys
# 2. Create a key with Admin or App Manager role
# 3. Note the Issuer ID, Key ID, and download the .p8 file
# 4. Base64-encode the .p8 contents for the KEY_CONTENT env var
