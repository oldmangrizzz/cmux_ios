# Fastfile for cmux_iOS
# Builds, signs, and uploads to TestFlight.

default_platform(:ios)

platform :ios do
  desc "Run unit tests"
  lane :test do
    scan(
      scheme: "cmux_iOS",
      destination: "platform=iOS Simulator,name=iPhone 16",
      clean: true
    )
  end

  desc "Build and upload to TestFlight"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY_KEY_CONTENT"],
      is_key_content_base64: false,
      in_house: false
    )

    # Generate xcodeproj from project.yml
    sh("cd .. && xcodegen")

    # Fetch signing certificates and provisioning profiles
    get_certificates(
      api_key: api_key,
      keychain_path: ENV["KEYCHAIN_PATH"] || "~/Library/Keychains/login.keychain-db"
    )
    get_provisioning_profile(
      api_key: api_key
    )

    # Increment build number
    increment_build_number(
      xcodeproj: "cmux_iOS.xcodeproj",
      build_number: latest_testflight_build_number(
        app_identifier: "com.cmuxterm.ios",
        api_key: api_key
      ) + 1
    )

    # Build the archive
    gym(
      scheme: "cmux_iOS",
      export_method: "app-store",
      clean: true,
      xcargs: "CODE_SIGN_STYLE=Manual DEVELOPMENT_TEAM=T5AFHQ4L9C PROVISIONING_PROFILE=2f6f539c-0944-4b32-a897-07a2683eb10c"
    )

    # Upload to TestFlight
    pilot(
      skip_waiting_for_build_processing: true,
      distribute_external: false,
      api_key: api_key
    )
  end

  desc "Register bundle ID and create App Store Connect app record"
  lane :register_app do
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY_KEY_CONTENT"],
      is_key_content_base64: false,
      in_house: false
    )

    produce(
      app_identifier: "com.cmuxterm.ios",
      app_name: "cmux",
      language: "English",
      sku: "cmux_ios_001",
      api_key: api_key
    )
  end

  desc "Set up code signing (run once locally)"
  lane :setup_signing do
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY_KEY_CONTENT"],
      is_key_content_base64: false,
      in_house: false
    )

    match(
      type: "appstore",
      app_identifier: "com.cmuxterm.ios",
      readonly: false,
      api_key: api_key
    )
  end
end
